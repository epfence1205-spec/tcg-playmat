{
  "enabled": true,
  "name": "Confirm Test Changes",
  "description": "Before modifying any test file, ask the user to confirm whether the test should be changed or whether the implementation logic should be fixed instead. Tests represent requirements — changing them to match broken behavior undermines their value.",
  "version": "1",
  "when": {
    "type": "preToolUse",
    "toolTypes": [
      "write"
    ]
  },
  "then": {
    "type": "askAgent",
    "prompt": "Check if this write operation targets a test file (*.test.ts, *.test.tsx, *.spec.ts, *.spec.tsx, or files in __tests__/). If it does, STOP and ask the user: \"This test failed — should I fix the implementation logic to pass the test, or do you want the test updated to reflect new requirements?\" Do NOT modify the test without explicit user approval. Tests represent requirements and changing them to match broken behavior undermines their value."
  }
}